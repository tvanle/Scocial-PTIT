# Server
PORT=3000
NODE_ENV=development

# Database (port 5434 khi chạy postgres qua docker-compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/ptit_social?schema=public"

# Redis (port 6381 khi chạy redis qua docker-compose)
REDIS_URL="redis://localhost:6381"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-secret-key"
JWT_REFRESH_EXPIRES_IN="30d"

# Upload
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES="image/jpeg,image/png,image/gif,image/webp,video/mp4"

# MinIO (S3-compatible storage) - CHANGE CREDENTIALS IN PRODUCTION
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_INTERNAL_URL="http://localhost:9000"
MINIO_PUBLIC_URL="http://localhost:9000"

# Firebase (for push notifications)
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# VNPay (for dating premium) - DEPRECATED, use VietQR instead
VNPAY_TMN_CODE="DEMOV210"
VNPAY_HASH_SECRET="SECRETKEY123456789"
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="ptitsocial://payment/vnpay-return"
# IPN URL must be publicly accessible (use ngrok for development)
VNPAY_IPN_URL="https://your-domain.com/api/v1/dating/payment/vnpay/ipn"

# VietQR (for dating premium)
VIETQR_BANK_ID="MB"
VIETQR_ACCOUNT_NO="0384190939"
VIETQR_ACCOUNT_NAME="NGUYEN DUONG THU"

# SePay API (for payment verification)
SEPAY_API_TOKEN="your-sepay-api-token"
