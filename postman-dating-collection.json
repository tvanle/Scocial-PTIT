{
  "info": {
    "name": "PTIT Social - Dating APIs",
    "description": "Collection để test các API liên quan đến tính năng Dating (hồ sơ, discovery, swipe, match).\n\n**Cách dùng:**\n1. Import collection vào Postman.\n2. Tạo Environment với biến: `baseUrl` = http://localhost:3001, `token` = JWT sau khi login.\n3. Chọn environment và gửi request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Profile",
      "item": [
        {
          "name": "Create dating profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Mình thích đi du lịch, đọc sách và cafe. Tìm bạn tâm sự và cùng trải nghiệm.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "profile"]
            },
            "description": "Tạo hồ sơ dating. Bio 10–500 ký tự. User phải >= 18 tuổi."
          }
        },
        {
          "name": "Update dating profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Mô tả đã cập nhật. Tối thiểu 10 ký tự.\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "profile"]
            },
            "description": "Cập nhật bio và/hoặc isActive."
          }
        },
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/profile/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "profile", "me"]
            },
            "description": "Lấy hồ sơ dating của user đang đăng nhập."
          }
        },
        {
          "name": "Get profile by userId",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/profile/:userId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "profile", ":userId"],
              "variable": [
                {
                  "key": "userId",
                  "value": ""
                }
              ]
            },
            "description": "Xem hồ sơ dating của user khác (truyền UUID vào :userId)."
          }
        },
        {
          "name": "Add photo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com/photo.jpg\",\n  \"order\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/profile/photos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "profile", "photos"]
            },
            "description": "Thêm ảnh vào hồ sơ. order 0–5, tối đa 6 ảnh."
          }
        },
        {
          "name": "Delete photo",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/profile/photos/:photoId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "profile", "photos", ":photoId"],
              "variable": [
                {
                  "key": "photoId",
                  "value": ""
                }
              ]
            },
            "description": "Xóa ảnh theo ID (UUID)."
          }
        },
        {
          "name": "Update prompts",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompts\": [\n    { \"question\": \"Điều tôi thích nhất vào cuối tuần?\", \"answer\": \"Cafe và đọc sách.\" },\n    { \"question\": \"Một nơi tôi muốn đến?\", \"answer\": \"Đà Lạt.\" }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/profile/prompts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "profile", "prompts"]
            },
            "description": "Cập nhật tối đa 3 câu hỏi-trivả lời."
          }
        },
        {
          "name": "Update lifestyle",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"education\": \"Đại học\",\n  \"job\": \"Developer\",\n  \"smoking\": \"NEVER\",\n  \"drinking\": \"SOMETIMES\",\n  \"exercise\": \"REGULARLY\",\n  \"height\": 175,\n  \"religion\": \"Không\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/profile/lifestyle",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "profile", "lifestyle"]
            },
            "description": "smoking/drinking/exercise: NEVER | SOMETIMES | REGULARLY. height: 100–250 cm."
          }
        },
        {
          "name": "Update preferences",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ageMin\": 20,\n  \"ageMax\": 35,\n  \"maxDistance\": 50,\n  \"gender\": \"FEMALE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/profile/preferences",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "profile", "preferences"]
            },
            "description": "ageMin/ageMax: 18–99, ageMin <= ageMax. gender: MALE | FEMALE | OTHER. maxDistance: km (1–500)."
          }
        }
      ]
    },
    {
      "name": "Discovery",
      "item": [
        {
          "name": "Get candidates",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/discovery?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "discovery"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Trang (optional)"
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Số item/trang (optional)"
                }
              ]
            },
            "description": "Lấy danh sách gợi ý để swipe, đã loại người đã swipe và theo preferences."
          }
        }
      ]
    },
    {
      "name": "Swipe",
      "item": [
        {
          "name": "Swipe (Like)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetUserId\": \"uuid-cua-nguoi-duoc-swipe\",\n  \"action\": \"LIKE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/swipe",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "swipe"]
            },
            "description": "Like người dùng. Nếu họ đã like mình trước đó → tạo match."
          }
        },
        {
          "name": "Swipe (Pass)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetUserId\": \"uuid-cua-nguoi-duoc-swipe\",\n  \"action\": \"PASS\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/swipe",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "swipe"]
            },
            "description": "Pass (bỏ qua) người dùng."
          }
        }
      ]
    },
    {
      "name": "Matches",
      "item": [
        {
          "name": "Get matches list",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/matches?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "matches"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Danh sách các match (cả hai đã like nhau)."
          }
        },
        {
          "name": "Get match detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/dating/matches/:matchId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dating", "matches", ":matchId"],
              "variable": [
                {
                  "key": "matchId",
                  "value": ""
                }
              ]
            },
            "description": "Chi tiết một match theo ID (UUID)."
          }
        }
      ]
    }
  ]
}
