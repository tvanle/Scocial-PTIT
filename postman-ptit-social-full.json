              "variable": [{ "key": "userId", "value": "" }]
            }
          }
        },
        {
          "name": "Get following",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/:userId/following",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", ":userId", "following"],
              "variable": [{ "key": "userId", "value": "" }]
            }
          }
        }
      ]
    },
