              "raw": "{\n  \"fullName\": \"Tên mới\",\n  \"bio\": \"Giới thiệu bản thân\",\n  \"dateOfBirth\": \"2000-01-01T00:00:00.000Z\",\n  \"gender\": \"MALE\",\n  \"phone\": \"0901234567\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/users/profile", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "profile"] }
          }
        },
        {
          "name": "Follow user",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/:userId/follow",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", ":userId", "follow"],
              "variable": [{ "key": "userId", "value": "" }]
            }
          }
        },
        {
          "name": "Unfollow user",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/:userId/follow",
              "host": ["{{baseUrl}}"],
